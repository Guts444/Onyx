<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="OnyxPageBackgroundColor">#FF07101A</Color>
    <Color x:Key="OnyxPanelBackgroundColor">#FF101A26</Color>
    <Color x:Key="OnyxPanelElevatedColor">#FF142232</Color>
    <Color x:Key="OnyxPanelBorderColor">#334D6D8A</Color>
    <Color x:Key="OnyxTextPrimaryColor">#FFF5F9FF</Color>
    <Color x:Key="OnyxTextSecondaryColor">#FFA8B4C4</Color>
    <Color x:Key="OnyxAccentColor">#FF4EB8FF</Color>
    <Color x:Key="OnyxAccentSoftColor">#334EB8FF</Color>

    <SolidColorBrush x:Key="OnyxPageBackgroundBrush" Color="{StaticResource OnyxPageBackgroundColor}" />
    <SolidColorBrush x:Key="OnyxPanelBackgroundBrush" Color="{StaticResource OnyxPanelBackgroundColor}" />
    <SolidColorBrush x:Key="OnyxPanelElevatedBrush" Color="{StaticResource OnyxPanelElevatedColor}" />
    <SolidColorBrush x:Key="OnyxPanelBorderBrush" Color="{StaticResource OnyxPanelBorderColor}" />
    <SolidColorBrush x:Key="OnyxTextPrimaryBrush" Color="{StaticResource OnyxTextPrimaryColor}" />
    <SolidColorBrush x:Key="OnyxTextSecondaryBrush" Color="{StaticResource OnyxTextSecondaryColor}" />
    <SolidColorBrush x:Key="OnyxAccentBrush" Color="{StaticResource OnyxAccentColor}" />
    <SolidColorBrush x:Key="OnyxAccentSoftBrush" Color="{StaticResource OnyxAccentSoftColor}" />

    <Style x:Key="OnyxPanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource OnyxPanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource OnyxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="18" />
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource OnyxTextPrimaryBrush}" />
    </Style>

    <Style TargetType="ListViewItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
</ResourceDictionary>
