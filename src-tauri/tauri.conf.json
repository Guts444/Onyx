{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Onyx",
  "version": "0.4.3",
  "identifier": "com.guts444.onyx",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Onyx",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "center": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https: http: data: blob:; connect-src ipc: http://ipc.localhost 'self' https: http: ws: wss:; media-src 'self' asset: https: http: data: blob:; font-src 'self' data: https: http:; object-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "lib/libmpv-2.dll",
      "lib/libmpv-wrapper.dll"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
